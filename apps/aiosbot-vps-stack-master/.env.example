# ============================================
# AIOSBot VPS Stack - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!

# === Identity ===
ORG_NAME=MyOrg
USER_NAME=Your Name
AGENT_NAME=Assistant

# === VPS Configuration ===
VPS_IP=1.2.3.4
GATEWAY_HOSTNAME=my-gateway
TAILNET_ID=your-tailnet-id
GATEWAY_PASSWORD=change-this-strong-password
HOOKS_TOKEN=your-webhook-token

# === Locale ===
TIMEZONE=UTC
LOCALE=en-US

# === LLM API Keys (at least one required) ===
OPENROUTER_API_KEY=sk-or-v1-...
ANTHROPIC_ADMIN_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
BRAVE_API_KEY=

# === Supabase (optional - for memory/database) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
DATABASE_URL=

# === Services (optional) ===
CLICKUP_API_KEY=
CLICKUP_TEAM_ID=
N8N_WEBHOOK_BASE=
N8N_API_KEY=
WHATSAPP_ADMIN_PHONE=
MEMORY_PATH=/home/aiosbot/workspace/memory

# === Advanced ===
LOG_LEVEL=info
LLM_ROUTER_ENABLED=true
LLM_ROUTER_DEFAULT_TIER=standard
DAILY_BUDGET_USD=20
